      "owner",
      "operation",
      "ordinal",
      "fault_model",
      "expected_reopen_result",
      "expected_authority",
      "expected_late_mutations_max"
    ],
    "coverage": "Every derived reachable boundary maps exactly once to each applicable fault model and expected outcome; tests prove registry-to-driver and driver-to-registry bijection.",
    "cardinality": "Computed from the frozen derived instances and asserted by tests; this design artifact deliberately does not invent a boundary or case count before implementation.",
    "single_fault": true,
    "late_mutations_max": 0,
    "physical_power_loss_eligible": false
  }
}
