{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helixos:schema:approval-decision:1",
  "title": "HelixOS Signed Approval Decision v1",
  "description": "Closed language-neutral wire shape for helixos.approval-decision/1. Typed validation additionally enforces exact PLAN-001, request-grant, task-lease, terminal-decision, trust, evidence, time and fencing relationships.",
  "$comment": "The complete UTF-8 wire is limited to 65536 bytes. JSON Schema cannot detect duplicate object names, prove RFC 8785 byte equality, validate signatures or determine whether a signed decision is current authority; the trust-boundary decoder and durable authority resolver enforce those rules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protected",
    "decision_digest",
    "signature"
  ],
  "properties": {
    "protected": {
      "$ref": "#/$defs/protectedDecision"
    },
    "decision_digest": {
      "$ref": "#/$defs/sha256Digest"
    },
    "signature": {
      "$ref": "#/$defs/ed25519Signature"
    }
  },
  "$defs": {
    "safeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "generation": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[-A-Za-z0-9._:]+$",
      "$comment": "Identifiers are opaque correlation values, never user content, credentials, bearer links, authentication assertions or native paths."
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonce128": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "ed25519Signature": {
      "type": "string",
      "minLength": 86,
      "maxLength": 86,
      "pattern": "^[A-Za-z0-9_-]{85}[AQgw]$",
      "$comment": "The decoder additionally decodes canonical unpadded base64url and requires exactly 64 Ed25519 signature bytes."
    },
    "protectedDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "digest_algorithm",
        "signature_algorithm",
        "key_purpose",
        "key_id",
        "decision_id",
        "issuer_id",
        "decision",
        "plan_id",
        "plan_envelope_digest",
        "operation_id",
        "plan_nonce",
        "task_id",
        "workload_id",
        "human_request_grant_id",
        "human_request_grant_digest",
        "grant_claim_generation",
        "task_lease_id",
        "task_lease_digest",
        "lease_projection_generation",
        "risk_level",
        "principal_id",
        "session_id",
        "authentication_profile",
        "authentication_evidence_digest",
        "authentication_evidence_generation",
        "policy_generation",
        "policy_content_digest",
        "policy_decision_digest",
        "catalogue_generation",
        "catalogue_content_digest",
        "catalogue_decision_digest",
        "clock_generation",
        "boot_id",
        "instance_epoch",
        "fencing_epoch",
        "issued_at_utc_ms",
        "expires_at_utc_ms",
        "issued_at_monotonic_ms",
        "deadline_monotonic_ms"
      ],
      "properties": {
        "schema": {
          "const": "helixos.approval-decision/1"
        },
        "digest_algorithm": {
          "const": "sha-256"
        },
        "signature_algorithm": {
          "const": "ed25519"
        },
        "key_purpose": {
          "const": "core-approval-decision-signing"
        },
        "key_id": {
          "$ref": "#/$defs/identifier"
        },
        "decision_id": {
          "$ref": "#/$defs/sha256Digest",
          "$comment": "Create-only terminal identity independent of signer key identity and PLAN-003 replay identity."
        },
        "issuer_id": {
          "$ref": "#/$defs/identifier",
          "$comment": "Configured core decision issuer; together with decision_id this is the durable namespace and must equal the indexed decision_issuer_id."
        },
        "decision": {
          "type": "string",
          "enum": [
            "APPROVED",
            "DENIED"
          ]
        },
        "plan_id": {
          "$ref": "#/$defs/sha256Digest",
          "$comment": "Exact PLAN-001 SHA-256 identifier of canonical protected plan bytes."
        },
        "plan_envelope_digest": {
          "$ref": "#/$defs/sha256Digest",
          "$comment": "SHA-256 of the exact canonical signed PLAN-001 envelope bytes; this adds a binding without changing the PLAN-001 wire."
        },
        "operation_id": {
          "$ref": "#/$defs/identifier"
        },
        "plan_nonce": {
          "$ref": "#/$defs/nonce128"
        },
        "task_id": {
          "$ref": "#/$defs/identifier"
        },
        "workload_id": {
          "$ref": "#/$defs/identifier"
        },
        "human_request_grant_id": {
          "$ref": "#/$defs/sha256Digest"
        },
        "human_request_grant_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "grant_claim_generation": {
          "$ref": "#/$defs/generation"
        },
        "task_lease_id": {
          "$ref": "#/$defs/sha256Digest"
        },
        "task_lease_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "lease_projection_generation": {
          "$ref": "#/$defs/generation"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "L0",
            "L1",
            "L2"
          ]
        },
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "session_id": {
          "$ref": "#/$defs/identifier"
        },
        "authentication_profile": {
          "type": "string",
          "enum": [
            "SESSION_AUTHENTICATED_V1",
            "USER_VERIFICATION_V1",
            "SYNTHETIC_CONFORMANCE_V1"
          ],
          "$comment": "A current positive L2 projection requires USER_VERIFICATION_V1. SYNTHETIC_CONFORMANCE_V1 may be decoded only as labelled test evidence and never qualifies as production authority."
        },
        "authentication_evidence_digest": {
          "$ref": "#/$defs/sha256Digest",
          "$comment": "Digest of bounded evidence metadata; raw authentication assertions, bearer tokens and credentials are forbidden."
        },
        "authentication_evidence_generation": {
          "$ref": "#/$defs/generation"
        },
        "policy_generation": {
          "$ref": "#/$defs/generation"
        },
        "policy_content_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "policy_decision_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "catalogue_generation": {
          "$ref": "#/$defs/generation"
        },
        "catalogue_content_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "catalogue_decision_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "clock_generation": {
          "$ref": "#/$defs/generation"
        },
        "boot_id": {
          "$ref": "#/$defs/identifier"
        },
        "instance_epoch": {
          "$ref": "#/$defs/safeInteger"
        },
        "fencing_epoch": {
          "$ref": "#/$defs/safeInteger"
        },
        "issued_at_utc_ms": {
          "$ref": "#/$defs/safeInteger"
        },
        "expires_at_utc_ms": {
          "$ref": "#/$defs/safeInteger",
          "$comment": "Exclusive UTC boundary no later than the plan, lease or source-grant boundary."
        },
        "issued_at_monotonic_ms": {
          "$ref": "#/$defs/safeInteger"
        },
        "deadline_monotonic_ms": {
          "$ref": "#/$defs/safeInteger",
          "$comment": "Exclusive same-boot boundary no later than the plan and lease monotonic bounds. Current UTC validation independently enforces the source-grant expiry."
        }
      }
    }
  }
}
