{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixos.local/schemas/recovery-snapshot-manifest-v1.schema.json",
  "title": "HelixOS Recovery Snapshot Manifest v1",
  "description": "Restricted canonical multi-provider inventory of material-present and retired-tombstone recovery evidence for one quiescent preparation backup cut. It is consistency evidence, not operation or compensation authority.",
  "$comment": "The stored file is exactly the RFC 8785 UTF-8 bytes of this complete object, with no BOM, prefix, suffix, whitespace or trailing newline; inventory_sha256 is lowercase SHA-256 of those exact bytes and is carried only by the top-level summary. The closed decoder rejects duplicate keys and additionally requires provider_set_count == provider_sets.length; provider sets strictly sorted and unique by (provider_profile_id, provider_id, provider_generation); each set entry_count == entries.length; total entry_count equal to the checked sum of group counts; entries strictly sorted and unique by lowercase package_binding_sha256; reserved_capacity >= material_length; and complete_reference_set coverage. no_retirement_pending additionally requires both top-level pending counts and the two authoritative coordinator/provider source counts to equal zero; provider enumeration contains no pending operation-bound or orphan retirement. JSON Schema cannot express those cross-field/order rules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "provider_set_count",
    "entry_count",
    "provider_sets",
    "complete_reference_set",
    "no_retirement_pending",
    "requires_paused_restore"
  ],
  "properties": {
    "schema": {
      "const": "helixos.recovery-snapshot/1"
    },
    "provider_set_count": {
      "$ref": "#/$defs/safeInteger"
    },
    "entry_count": {
      "$ref": "#/$defs/safeInteger"
    },
    "provider_sets": {
      "type": "array",
      "maxItems": 1000000,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider_profile_id",
          "provider_profile_version",
          "provider_id",
          "provider_generation",
          "evidence_class",
          "at_rest_profile_id",
          "entry_count",
          "entries"
        ],
        "properties": {
          "provider_profile_id": {
            "$ref": "#/$defs/identifier"
          },
          "provider_profile_version": {
            "const": 1
          },
          "provider_id": {
            "$ref": "#/$defs/identifier"
          },
          "provider_generation": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "evidence_class": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Z0-9_]+$"
          },
          "at_rest_profile_id": {
            "$ref": "#/$defs/identifier"
          },
          "entry_count": {
            "$ref": "#/$defs/safeInteger"
          },
          "entries": {
            "type": "array",
            "maxItems": 1000000,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "package_binding_sha256",
                "manifest_sha256",
                "material_sha256",
                "material_length",
                "reserved_capacity",
                "custody",
                "state"
              ],
              "properties": {
                "package_binding_sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "manifest_sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "material_sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "material_length": {
                  "$ref": "#/$defs/safeInteger"
                },
                "reserved_capacity": {
                  "$ref": "#/$defs/safeInteger"
                },
                "custody": {
                  "enum": [
                    "OPERATION_BOUND",
                    "QUARANTINED_ORPHAN",
                    "ORPHAN_RESOLUTION_TOMBSTONE"
                  ]
                },
                "state": {
                  "enum": [
                    "MATERIAL_PRESENT",
                    "RETIRED_TOMBSTONE"
                  ]
                },
                "retirement_manifest_sha256": {
                  "$ref": "#/$defs/sha256"
                }
              },
              "allOf": [
                {
                  "if": {
                    "required": [
                      "state"
                    ],
                    "properties": {
                      "state": {
                        "const": "RETIRED_TOMBSTONE"
                      }
                    }
                  },
                  "then": {
                    "required": [
                      "retirement_manifest_sha256"
                    ]
                  },
                  "else": {
                    "not": {
                      "required": [
                        "retirement_manifest_sha256"
                      ]
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "state": {
                        "const": "MATERIAL_PRESENT"
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "custody": {
                        "enum": [
                          "OPERATION_BOUND",
                          "QUARANTINED_ORPHAN"
                        ]
                      }
                    }
                  },
                  "else": {
                    "properties": {
                      "custody": {
                        "enum": [
                          "OPERATION_BOUND",
                          "ORPHAN_RESOLUTION_TOMBSTONE"
                        ]
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "complete_reference_set": {
      "const": true
    },
    "no_retirement_pending": {
      "const": true
    },
    "requires_paused_restore": {
      "const": true
    }
  },
  "$defs": {
    "safeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
